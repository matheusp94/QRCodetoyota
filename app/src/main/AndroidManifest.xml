<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:sharedUserId="android.ui.system">

    <!-- Target Device: Toyota TAS700 VR (Android Automotive) -->

    <!-- Android Automotive Feature -->
    <uses-feature android:name="android.hardware.type.automotive" android:required="true" />

    <!-- Car API Permissions -->
    <uses-permission android:name="android.car.permission.CAR_DYNAMICS" />
    <uses-permission android:name="android.car.permission.CAR_IDENTIFICATION" />
    <uses-permission android:name="android.permission.READ_LOGS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QRCodetoyota">

        <activity
            android:name="com.tta.qrcodetoyota.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>